# ╔══════════════════════════════════════════════╗
# ║        🔐  ENVIRONMENT VARIABLES             ║
# ║  Copy this to .env and fill in your values   ║
# ╚══════════════════════════════════════════════╝

# ── Get from my.telegram.org ──────────────────
API_ID=12345678
API_HASH=your_api_hash_here

# ── Get from @BotFather ───────────────────────
BOT_TOKEN=123456789:ABCdef_your_bot_token

# ── Pyrogram string session (userbot) ─────────
# Generate using: python generate_session.py
STRING_SESSION=your_pyrogram_string_session

# ── Optional tuning ───────────────────────────
MAX_QUEUE=10
DEFAULT_VOLUME=100
SEARCH_COOLDOWN=5
